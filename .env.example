# Praetor local / prototype environment

# App URLs and ports
PRAETOR_BIND_HOST=127.0.0.1
PRAETOR_WEB_PORT=3000
PRAETOR_APP_URL=http://localhost:3000

# Deployment mode
PRAETOR_ENV=local
PRAETOR_RUNTIME_MODE=api
PRAETOR_REQUIRE_LOGIN=true
PRAETOR_SECURE_COOKIE=false
PRAETOR_TRUST_PROXY=false
PRAETOR_RATE_LIMIT_ENABLED=false
PRAETOR_DEBUG_ROUTES=true

# Paths on host
PRAETOR_WORKSPACE_DIR=./workspace
PRAETOR_CONFIG_DIR=./config
PRAETOR_DATA_DIR=./data
PRAETOR_OLLAMA_DIR=./ollama
PRAETOR_BACKUP_DIR=./backups
PRAETOR_PROXY_DATA_DIR=./data/caddy
PRAETOR_PROXY_CONFIG_DIR=./config/caddy

# Important for subscription executor mode:
# This is the host path that the host executor bridge will use when invoking
# codex or claude on the machine outside Docker.
PRAETOR_HOST_WORKSPACE_ROOT=/absolute/path/to/praetor/workspace

# Session / auth
# Generate real values with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
PRAETOR_SESSION_SECRET=
PRAETOR_SETUP_TOKEN=
PRAETOR_SECRETS_DIR=./secrets

# Executor bridge
PRAETOR_BRIDGE_BASE_URL=http://host.docker.internal:9417
PRAETOR_BRIDGE_TOKEN=
PRAETOR_ALLOWED_EXECUTORS=codex,claude_code

# To use your existing Codex / Claude Code subscription instead:
# PRAETOR_RUNTIME_MODE=subscription_executor
# and run praetor-execd on the host.

# Optional API providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PRAETOR_CEO_PLANNER_MODE=auto
PRAETOR_CEO_PLANNER_PROVIDER=openai
PRAETOR_CEO_PLANNER_MODEL=gpt-4.1-mini

# Optional Telegram integration
PRAETOR_ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# Optional Ollama
PRAETOR_OLLAMA_PORT=11434

# Production / remote
PRAETOR_DOMAIN=
